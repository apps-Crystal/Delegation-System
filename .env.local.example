# ---------------------------------------------------------------
# Copy this file to .env.local and fill in your values.
# ---------------------------------------------------------------

# Google Sheet ID (the long string between /d/ and /edit in the URL)
GOOGLE_SHEET_ID=1YFHkJ9Am09Y_nIIRgNDbxCII02jc9zvPvOf1s1n29dU

# Google API key restricted to Sheets + Drive APIs.
# Used for READING the sheet only.
# Server-side only — DO NOT prefix with NEXT_PUBLIC_.
GOOGLE_API_KEY=AIzaSyBmJUObiEGTpBKH11-xrXWBHz1sOnjZ334

# Apps Script Web App URL — used for WRITING to the sheet.
# See apps-script.gs in the project root for the script to deploy.
# Leave empty to disable writes (read-only mode).
APPS_SCRIPT_URL=

# Sheet tab names — must match the actual tab titles in your spreadsheet.
# Sheets API tab names are case-sensitive; spaces are allowed.
DOERLIST_SHEET=Doer List
MASTER_SHEET=Master
